<%= simple_form_for [chat, message], html: { class: "chat-form" } do |f| %>
  <div class="d-flex gap-2 align-items-end">
    <%= f.input :content,
      label: false,
      placeholder: "I'm in the mood for...",
      required: true,
      wrapper_html: { class: "flex-grow-1 mb-0" },
      input_html: { class: "form-control chat-input", rows: 1 } %>

    <%= f.button :submit, "Send", class: "btn btn-primary chat-send px-4" %>
  </div>
<% end %>
