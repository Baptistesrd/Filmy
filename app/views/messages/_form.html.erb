<%= simple_form_for [chat, message],
      html: { class: "chat-form", multipart: true, data: { controller: "message-form" } } do |f| %>

  <div id="image-preview-container"></div>

  <div class="chat-form-row">
    <%= f.input :content,
          label: false,
          placeholder: "What are you in the mood for?",
          required: false,
          wrapper_html: { class: "flex-grow-1 mb-0" },
          input_html: {
            class: "chat-input",
            rows: 1,
            data: { "message-form-target": "input", action: "keydown->message-form#submitOnEnter" }
          } %>

    <label class="chat-upload-btn" title="Attach image">
      <i class="fa-solid fa-paperclip" style="font-size:0.85rem"></i>
      <%= f.file_field :image,
            accept: "image/png,image/jpeg,image/gif,image/webp",
            class: "d-none",
            id: "image-upload",
            data: { action: "change->message-form#previewImage" } %>
    </label>

    <button type="submit" class="chat-send-btn" aria-label="Send message">
      <i class="fa-solid fa-arrow-up" style="font-size:0.85rem"></i>
    </button>
  </div>

<% end %>
