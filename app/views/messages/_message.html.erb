<% is_user = message.role.to_s == "user" %>

<% if is_user %>
  <div class="chat-row chat-row--user">
    <div class="chat-bubble chat-bubble--user">
      <% if message.image.attached? %>
        <%= image_tag url_for(message.image),
              alt: "Uploaded image",
              style: "max-width: 220px; border-radius: 8px; display: block; margin-bottom: 8px;" %>
      <% end %>
      <% if message.content.present? %>
        <%= simple_format(h(message.content), {}, wrapper_tag: "div") %>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="chat-row chat-row--assistant" id="message_<%= message.id %>">
    <div class="chat-bubble chat-bubble--assistant">
      <% if message.content.present? %>
        <%= simple_format(
              h(message.content).gsub(/\*\*(.*?)\*\*/, '<strong>\1</strong>').html_safe,
              {},
              wrapper_tag: "div"
            ) %>
      <% else %>
        <div class="typing-indicator">
          <span></span><span></span><span></span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
