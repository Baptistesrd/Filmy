<div class="container py-4">
  <div class="row g-4">

    <div class="col-lg-8">
      <h1 class="fw-bold mb-3"><%= @watch_session.title %></h1>

      <div class="mb-4">
        <% if @watch_session.description.present? %>
          <%= raw(render_markdown(@watch_session.description)) %>
        <% else %>
          <p class="text-muted">No description yet.</p>
        <% end %>
      </div>

      <div class="d-flex gap-2 mb-4">
        <%= link_to "Edit session", edit_watch_session_path(@watch_session), class: "btn btn-outline-secondary" %>
      </div>

      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h5 mb-0 text-dark">Watchlist</h2>
            <span class="badge text-bg-light"><%= @films&.count.to_i %></span>
          </div>

          <% if @films.present? && @films.any? %>
            <div class="row g-3">
              <% @films.each do |film| %>
                <div class="col-12 col-md-6">
                  <div class="card h-100 border-0" style="background: rgba(255,255,255,0.92);">
                    <div class="card-body p-3">
                      <div class="d-flex justify-content-between align-items-start gap-2">
                        <div class="flex-grow-1">
                          <div class="fw-bold text-dark">
                            <%= film.title %>
                            <% if film.year.present? %>
                              (<%= film.year %>)
                            <% end %>
                          </div>

                          <% if film.runtime.present? %>
                            <div class="small text-muted mt-1">
                              <%= film.runtime %> min
                            </div>
                          <% end %>

                          <% if film.genre.present? %>
                            <div class="small text-muted mt-1">
                              <%= film.genre %>
                            </div>
                          <% end %>

                          <% if film.streaming_services.present? %>
                            <div class="small text-dark mt-2">
                              <strong>Watch on:</strong>
                              <%= film.streaming_services %>
                            </div>
                          <% else %>
                            <div class="small text-muted mt-2">
                              Streaming info coming soon
                            </div>
                          <% end %>

                          <% if film.justwatch_url.present? %>
                            <div class="mt-2">
                              <%= link_to "View on JustWatch",
                                  film.justwatch_url,
                                  target: "_blank",
                                  class: "btn btn-sm btn-outline-secondary" %>
                            </div>
                          <% end %>
                        </div>

                        <span class="badge text-bg-secondary">Saved</span>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted mb-0">
              No films saved yet. Add films from a chat to build your watchlist.
            </p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">

          <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h5 mb-0 text-dark">Chats</h2>

            <%= button_to "New chat",
                  watch_session_chats_path(@watch_session),
                  method: :post,
                  class: "btn btn-primary btn-sm" %>
          </div>

          <% if @chats.any? %>
            <div class="list-group list-group-flush">
              <% @chats.each do |chat| %>
                <div class="d-flex justify-content-between align-items-center py-3 border-top">
                  <%= link_to chat_path(chat), class: "text-decoration-none flex-grow-1 me-2" do %>
                    <div class="text-dark fw-semibold"><%= chat.title.presence || "Untitled" %></div>
                    <div class="text-muted small"><%= chat.created_at.strftime("%d %b %Y • %H:%M") %></div>
                  <% end %>

                  <%= button_to chat_path(chat),
                        method: :delete,
                        data: { turbo_confirm: "Delete this chat?" },
                        class: "btn btn-sm btn-outline-danger",
                        form: { class: "m-0" } do %>
                    <span class="d-inline-flex align-items-center">
                      <i class="fa-solid fa-trash"></i>
                      <span class="ms-1 d-none">Delete</span>
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted mb-0">There are no chats yet.</p>
          <% end %>

        </div>
      </div>
    </div>

  </div>
</div>
