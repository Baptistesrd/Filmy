<div class="container py-4">
  <div class="row g-4">

    <div class="col-lg-8">
      <h1 class="fw-bold mb-2 text-white"><%= @watch_session.title %></h1>

      <% if @watch_session.description.present? %>
        <p class="text-white-50 mb-4">
          <%= raw(render_markdown(@watch_session.description)) %>
        </p>
      <% else %>
        <p class="text-white-50 mb-4">No description yet.</p>
      <% end %>

      <div class="d-flex gap-2">
        <%= link_to "Edit session",
              edit_watch_session_path(@watch_session),
              class: "btn btn-outline-light" %>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">

          <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h5 mb-0 text-dark">Chats</h2>

            <%= button_to "New chat",
                  watch_session_chats_path(@watch_session),
                  method: :post,
                  class: "btn btn-primary btn-sm" %>
          </div>

          <% if @chats.any? %>
            <div class="list-group list-group-flush">
              <% @chats.each do |chat| %>
                <%= link_to chat_path(chat),
                      class: "list-group-item list-group-item-action d-flex align-items-center justify-content-between py-3" do %>

                  <div class="me-2" style="min-width: 0;">
                    <div class="fw-semibold text-dark text-truncate">
                      <%= chat.title.presence || "Untitled" %>
                    </div>
                    <small class="text-muted">
                      <%= chat.created_at.strftime("%d %b %Y • %H:%M") %>
                    </small>
                  </div>

                  <span class="text-muted">›</span>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted mb-0">There are no chats yet.</p>
          <% end %>

        </div>
      </div>
    </div>

  </div>
</div>
