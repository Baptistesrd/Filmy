<div class="session-hero">
  <p class="session-hero-kicker">Watch Session</p>
  <h1 class="session-hero-title"><%= @watch_session.title %></h1>

  <div class="session-hero-chips">
    <% if @watch_session.genre.present? %>
      <span class="ws-chip"><%= @watch_session.genre %></span>
    <% end %>
    <% if @watch_session.mood.present? %>
      <span class="ws-chip"><%= @watch_session.mood %></span>
    <% end %>
  </div>

  <% if @watch_session.description.present? %>
    <p style="color:var(--text-muted);margin-top:12px;font-size:0.9375rem;line-height:1.6;">
      <%= @watch_session.description %>
    </p>
  <% end %>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="section-heading" style="font-size:1.5rem">Chats</h2>
      <%= button_to "New chat",
            watch_session_chats_path(@watch_session),
            method: :post,
            class: "btn btn-primary btn-sm" %>
    </div>

    <div style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;">
      <% if @chats.any? %>
        <% @chats.each do |chat| %>
          <div class="chat-list-item px-4">
            <%= link_to chat_path(chat), class: "flex-grow-1 me-3" do %>
              <div class="chat-list-title"><%= chat.title.presence || "Untitled" %></div>
              <div class="chat-list-date"><%= chat.created_at.strftime("%d %b %Y · %H:%M") %></div>
            <% end %>

            <%= button_to chat_path(chat),
                  method: :delete,
                  data: { turbo_confirm: "Delete this chat?" },
                  class: "btn btn-outline-danger btn-sm",
                  form: { class: "m-0" } do %>
              <i class="fa-solid fa-trash" style="font-size:0.75rem"></i>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="empty-state" style="padding:32px">
          <i class="fa-regular fa-comment-dots"></i>
          <p>No chats yet — start one above.</p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="section-heading" style="font-size:1.5rem">Actions</h2>
    </div>
    <div style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px;display:flex;flex-direction:column;gap:10px;">
      <%= link_to edit_watch_session_path(@watch_session), class: "btn btn-secondary w-100" do %>
        <i class="fa-solid fa-pen" style="font-size:0.8rem"></i> Edit session
      <% end %>
      <%= link_to films_path, class: "btn btn-outline-light w-100" do %>
        <i class="fa-solid fa-bookmark" style="font-size:0.8rem"></i> My film library
      <% end %>
    </div>
  </div>
</div>
