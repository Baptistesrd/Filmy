<%# ── Hero ──────────────────────────────────────────────────────────────────── %>
<div class="sessions-hero">
  <div class="sessions-hero-inner">
    <h1 class="sessions-hero-title">Your Sessions</h1>
    <%= link_to new_watch_session_path, class: "btn btn-primary" do %>
      <i class="fa-solid fa-plus" style="font-size:0.8rem"></i>
      New session
    <% end %>
  </div>
</div>

<%# ── Content ───────────────────────────────────────────────────────────────── %>
<div class="sessions-body">
  <% if @watch_sessions.any? %>
    <div class="sessions-grid">
      <% @watch_sessions.each do |watch_session| %>
        <%= render "card", watch_session: watch_session %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <i class="fa-regular fa-film"></i>
      <h3>No sessions yet</h3>
      <p>Create your first session to start getting film recommendations.</p>
      <%= link_to "Start your first session", new_watch_session_path, class: "btn btn-primary mt-3" %>
    </div>
  <% end %>
</div>
