<div class="row justify-content-center">
  <div class="col-12 col-md-10 col-lg-8">
    <div class="form-page-card">
      <div class="d-flex justify-content-between align-items-start mb-4">
        <h1 class="section-heading" style="font-size:2rem">Edit Session</h1>
        <%= link_to watch_session_path(@watch_session), class: "btn btn-outline-light btn-sm" do %>
          <i class="fa-solid fa-xmark"></i>
        <% end %>
      </div>

      <%= render "form", watch_session: @watch_session %>
    </div>
  </div>
</div>
