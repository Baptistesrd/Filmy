<%= simple_form_for @watch_session do |f| %>
  <%= f.input :title %>
  <%= f.input :description %>

  <%= f.input :genre,
              collection: WatchSession::GENRES,
              prompt: "Select a genre",
              input_html: { class: "form-select" } %>

  <%= f.input :mood,
              collection: WatchSession::MOODS,
              prompt: "Select a mood",
              input_html: { class: "form-select" } %>

  <%= f.input :movie_or_show_name, label: "Movie or Show Name" %>

  <%= f.button :submit, class: "btn btn-primary" %>
<% end %>
