<% genres = [
  "Action", "Adventure", "Animation", "Comedy", "Crime", "Documentary", "Drama",
  "Fantasy", "Horror", "Mystery", "Romance", "Sci-Fi", "Thriller", "War", "Western",
  "Family", "Musical", "Sport"
] %>

<% moods = [
  "Chill", "Feel-good", "Funny", "Romantic", "Dark", "Emotional", "Hype",
  "Mind-bending", "Cozy", "Scary", "Inspiring", "Adventurous"
] %>

<%= simple_form_for(@watch_session) do |f| %>
  <% if @watch_session.errors.any? %>
    <div class="alert alert-danger">
      <p class="mb-2"><strong>Please fix the errors below:</strong></p>
      <ul class="mb-0">
        <% @watch_session.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @watch_session.respond_to?(:title) %>
    <%= f.input :title, input_html: { class: "form-control placeholder-fade" },placeholder: "Give this watch session a name (e.g. Friday Night Movies)"  %>
  <% end %>

  <% if @watch_session.respond_to?(:description) %>
    <%= f.input :description, as: :text, input_html: { class: "form-control placeholder-fade", rows: 4 }, placeholder: "Describe what kind of movie you're planning on watching..."%>
  <% end %>

  <%= f.input :genre,
              collection: genres,
              prompt: "Select a genre",
              input_html: { class: "form-select placeholder-fade" },
              placeholder: "e.g. Comedy, Thriller, Sci-Fi, Romance"%>

  <%= f.input :mood,
              collection: moods,
              prompt: "Select a mood",
              input_html: { class: "form-select placeholder-fade" },
              placeholder: "What kind of movie are you in the mood to watch right now? e.g. cozy, adventurous, emotional"%>

  <div class="d-flex gap-2 mt-4 ">
    <%= f.button :submit, "Start Watch Session", class: "btn btn-secondary rounded-pill px-4 py-2 shadow-sm " %>
    <%= link_to "Cancel", (@watch_session.persisted? ? watch_session_path(@watch_session) : root_path), class: "btn btn-outline-secondary rounded-pill" %>
  </div>
<% end %>
