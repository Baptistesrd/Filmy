<% genres = defined?(WatchSession::GENRES) ? WatchSession::GENRES : [] %>
<% moods  = defined?(WatchSession::MOODS)  ? WatchSession::MOODS  : [] %>

<%= simple_form_for(watch_session) do |f| %>
  <div class="mb-3">
    <%= f.input :title, input_html: { class: "form-control" } %>
  </div>

  <% if watch_session.respond_to?(:description) %>
    <div class="mb-3">
      <%= f.input :description, as: :text, input_html: { class: "form-control", rows: 3 } %>
    </div>
  <% end %>

  <% if watch_session.respond_to?(:genre) %>
    <div class="mb-3">
      <%= f.input :genre,
        collection: genres,
        prompt: "Select a genre",
        input_html: { class: "form-select" } %>
    </div>
  <% end %>

  <% if watch_session.respond_to?(:mood) %>
    <div class="mb-3">
      <%= f.input :mood,
        collection: moods,
        prompt: "Select a mood",
        input_html: { class: "form-select" } %>
    </div>
  <% end %>

  <% if watch_session.respond_to?(:movie_or_show_name) %>
    <div class="mb-4">
      <%= f.input :movie_or_show_name, label: "Movie or Show Name", input_html: { class: "form-control" } %>
    </div>
  <% end %>

  <div class="d-flex gap-2">
    <%= f.button :submit, class: "btn btn-primary" %>
    <%= link_to "Cancel", watch_sessions_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
