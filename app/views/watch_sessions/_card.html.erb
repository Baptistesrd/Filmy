<div class="ws-card">
  <div style="position:absolute;top:12px;right:12px;">
    <%= button_to watch_session_path(watch_session),
          method: :delete,
          class: "mac-close-btn",
          form: { data: { turbo_confirm: "Delete this session?" } } do %>
      <span class="mac-close-icon">✕</span>
    <% end %>
  </div>

  <div class="ws-card-title"><%= watch_session.title.presence || "Untitled session" %></div>

  <div class="ws-card-chips">
    <% if watch_session.genre.present? %>
      <span class="ws-chip"><%= watch_session.genre %></span>
    <% end %>
    <% if watch_session.mood.present? %>
      <span class="ws-chip"><%= watch_session.mood %></span>
    <% end %>
  </div>

  <% if watch_session.description.present? %>
    <p class="ws-card-desc"><%= watch_session.description %></p>
  <% end %>

  <div class="ws-card-footer">
    <%= link_to watch_session_path(watch_session), class: "btn btn-secondary btn-sm" do %>
      <i class="fa-solid fa-play" style="font-size:0.7rem"></i> Open
    <% end %>
    <%= link_to edit_watch_session_path(watch_session), class: "btn btn-outline-light btn-sm" do %>
      <i class="fa-solid fa-pen" style="font-size:0.7rem"></i>
    <% end %>
  </div>
</div>
