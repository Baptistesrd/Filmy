<div class="card shadow-sm h-100 position-relative">

  <%= button_to watch_session_path(watch_session),
        method: :delete,
        class: "mac-close-btn",
        form: { data: { turbo_confirm: "Delete this session?" } } do %>
    <span class="mac-close-icon">✕</span>
  <% end %>

  <div class="card-body">
    <h5 class="card-title mb-1"><%= watch_session.title.presence || "Untitled session" %></h5>

    <div class="d-flex flex-wrap gap-2 my-2">
      <% if watch_session.genre.present? %>
        <span class="badge text-bg-secondary"><%= watch_session.genre %></span>
      <% end %>
      <% if watch_session.mood.present? %>
        <span class="badge text-bg-dark"><%= watch_session.mood %></span>
      <% end %>
    </div>

    <% if watch_session.description.present? %>
      <p class="card-text text-muted mb-3">
        <%= truncate(watch_session.description, length: 120) %>
      </p>
    <% end %>
  </div>

  <div class="card-footer bg-white border-0 pt-0 pb-3 px-3">
    <div class="d-flex gap-2">
      <%= link_to watch_session_path(watch_session), class: "btn btn-sm btn-dark rounded-pill px-3 mt-3" do %>
        <i class="fa-solid fa-play me-1"></i> Open
      <% end %>
      <%= link_to edit_watch_session_path(watch_session), class: "btn btn-sm btn-outline-secondary rounded-pill px-3 mt-3" do %>
        <i class="fa-solid fa-pen me-1"></i> Edit
      <% end %>
    </div>
  </div>

</div>

