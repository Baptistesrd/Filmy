<%= link_to "← #{@chat.watch_session.name}", watch_seesion_path(@chat.watch_session) %>

<h1 id="chat_title"><%= @chat.title %></h1>

<div id="new_message_container">
  <%= simple_form_for [@chat, @message] do |f| %>
    <%= f.input :content, label: "What are you in the mood for?", required: true, placeholder: "Im in the mood for..." %>
    <%= f.button :submit, 'Ask LLM', class: 'btn btn-primary' %>
  <% end %>
</div>
