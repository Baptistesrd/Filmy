<div class="container py-4" style="max-width: 900px;">

  <%= link_to watch_session_path(@chat.watch_session),
              class: "d-inline-flex align-items-center gap-2 text-decoration-none text-muted mb-3" do %>
    <span>←</span>
    <span><%= @chat.watch_session.title %></span>
  <% end %>

  <h1 class="fw-bold mb-4" id="chat_title"><%= @chat.title %></h1>

  <div class="d-flex flex-column gap-3 mb-4" id="messages">

    <% @messages.each do |message| %>

      <%= render "messages/message", message: message %>

      </div>

    <% end %>

  </div>

  <div class="card border-0 shadow-sm rounded-4" id="new_message_container">
    <div class="card-body p-3">

      <%= render "messages/form", chat: @chat, message: @message  %>

    </div>
  </div>

</div>
