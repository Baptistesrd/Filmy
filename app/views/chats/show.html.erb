<div class="chat-page container-fluid py-4">
  <div class="chat-wrapper mx-auto">
    <%= link_to watch_session_path(@chat.watch_session),
        class: "btn btn-sm btn-outline-light mb-3 d-inline-flex align-items-center gap-2" do %>
      <span>←</span>
      <span><%= @chat.watch_session.title %></span>
    <% end %>

    <h1 class="fw-bold mb-3" id="chat_title" style="font-size: clamp(1.6rem, 3.2vw, 2.4rem);">
      <%= @chat.title %>
    </h1>

    <div class="row g-4 align-items-start">
      <div class="col-12 col-lg-8">
        <div
          class="chat-shell rounded-4 shadow-sm"
          data-controller="chat-scroll"
        >
          <div
            class="chat-messages"
            id="messages"
            data-chat-scroll-target="messages"
          >
            <%= render partial: "messages/message",
                collection: @messages,
                as: :message %>
          </div>

          <div
            class="chat-composer border-top"
            id="new_message_container"
          >
            <%= render "messages/form",
                chat: @chat,
                message: @message %>
          </div>
        </div>
      </div>

      <div class="col-12 col-lg-4">
        <div class="rounded-4 shadow-sm p-3" style="background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.08);">
          <div class="d-flex align-items-center justify-content-between mb-3">
            <h2 class="h6 mb-0">Recommended</h2>
            <span class="badge text-bg-light"><%= @chat.recommended_films.count %></span>
          </div>

          <% if @chat.recommended_films.any? %>
            <div class="d-grid gap-3">
              <% @chat.recommended_films.order(created_at: :desc).each do |film| %>
                <div class="card border-0" style="background: rgba(255, 255, 255, 0.92);">
                  <div class="card-body p-3">
                    <div class="d-flex align-items-start justify-content-between gap-2">
                      <div class="me-2">
                        <div class="fw-bold text-dark">
                          <%= film.title %><% if film.year.present? %> (<%= film.year %>)<% end %>
                        </div>
                        <% if film.runtime.present? %>
                          <div class="small text-muted"><%= film.runtime %> min</div>
                        <% end %>
                      </div>

                      <button type="button" class="btn btn-sm btn-primary" disabled title="Coming next: add to watchlist">
                        +
                      </button>
                    </div>

                    <% if film.blurb.present? %>
                      <p class="small text-dark mb-0 mt-2"><%= film.blurb %></p>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="small mb-0" style="color: rgba(255,255,255,0.7);">
              Ask for recommendations and they'll appear here.
            </p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
