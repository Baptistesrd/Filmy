<div class="container py-4" style="max-width: 800px;">

  <%= link_to watch_session_path(@chat.watch_session), class: "d-inline-flex align-items-center gap-2 text-decoration-none text-muted mb-4" do %>
    <span>←</span>
    <span><%= @chat.watch_session.title %></span>
  <% end %>

  <h1 class="fw-bold mb-4" id="chat_title"><%= @chat.title %></h1>

  <div class="d-flex flex-column gap-3 mb-4">
    <% @messages.each do |message| %>
      <div class="d-flex <%= message.role == 'user' ? 'justify-content-end' : 'justify-content-start' %>">
        <div class="px-3 py-2 rounded-3" style="max-width: 75%; <%= message.role == 'assistant' ? 'background: #f0f4ff; color: #2d3a8c;' : 'background: #e9ecef; color: #212529;' %>">
          <%= message.content %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="card border-0 shadow-sm rounded-3" id="new_message_container">
    <div class="card-body p-3">
      <%= simple_form_for [@chat, @message] do |f| %>
        <div class="d-flex gap-2 align-items-end">
          <%= f.input :content,
              label: false,
              placeholder: "I'm in the mood for...",
              required: true,
              wrapper_html: { class: "flex-grow-1 mb-0" },
              input_html: { class: "form-control border-0 bg-light rounded-3", rows: 1 } %>
          <%= f.button :submit, 'Ask', class: 'btn btn-primary rounded-3 px-4' %>
        </div>
      <% end %>
    </div>
  </div>

</div>