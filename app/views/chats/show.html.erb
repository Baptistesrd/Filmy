<%= turbo_stream_from "chat_#{@chat.id}" %>

<div class="chat-page container-fluid py-4">
  <div class="chat-wrapper mx-auto">

    <%= link_to watch_session_path(@chat.watch_session),
        class: "btn btn-sm btn-outline-light mb-3 d-inline-flex align-items-center gap-2" do %>
      <span>←</span>
      <span><%= @chat.watch_session.title %></span>
    <% end %>

    <h1 class="fw-bold mb-2" id="chat_title" style="font-size: clamp(1.6rem, 3.2vw, 2.4rem);">
      <%= @chat.title %>
    </h1>

    <div class="row g-4 align-items-start">
      <div class="col-lg-8">
        <div class="chat-shell rounded-4 shadow-sm" data-controller="chat-scroll">
          <div class="chat-messages" id="messages" data-chat-scroll-target="messages">
            <%= render partial: "messages/message", collection: @messages, as: :message %>
          </div>

          <div class="chat-composer border-top" id="new_message_container">
            <%= render "messages/form", chat: @chat, message: @message %>
          </div>
        </div>
      </div>

      <div class="col-lg-4 btn btn-secondary px-4 py-2 rounded-pill ">
        <div id="recommended_panel">
          <%= render "recommended_films/panel", chat: @chat, recommended_films: @recommended_films %>
        </div>
      </div>
    </div>

  </div>
</div>
