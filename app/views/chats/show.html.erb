<div class="container py-4" style="max-width: 900px;">

  <%= link_to watch_session_path(@chat.watch_session),
      class: "btn btn-outline-light mb-4 d-inline-flex align-items-center gap-2" do %>
    <span>←</span>
    <span><%= @chat.watch_session.title %></span>
  <% end %>

  <h1 class="fw-bold mb-4 text-white"><%= @chat.title %></h1>

  <div id="messages" class="d-flex flex-column gap-3 mb-4 w-100">

    <% @messages.each do |message| %>
      <% is_user = message.role == "user" %>

      <div class="w-100 d-flex <%= is_user ? "justify-content-end" : "justify-content-start" %>">

        <div
          style="
            max-width: 70%;
            padding: 10px 14px;
            border-radius: 18px;
            white-space: pre-wrap;
            line-height: 1.4;
            <%= is_user ?
              'background:#0d6efd;color:white;border-bottom-right-radius:6px;' :
              'background:#f1f3f5;color:#111;border-bottom-left-radius:6px;' %>
          "
        >
          <%= message.content %>
        </div>

      </div>

    <% end %>

  </div>

  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-3">

      <%= render "messages/form", chat: @chat, message: @message %>
    </div>
  </div>

</div>
