<div class="container py-4" style="max-width: 900px;">

  <%= link_to watch_session_path(@chat.watch_session),
      class: "d-inline-flex align-items-center gap-2 mb-3 px-2 py-1 rounded text-white",
      style: "border: 1px solid rgba(255,255,255,.2); background: rgba(0,0,0,.25);" do %>
    <span>←</span>
    <span><%= @chat.watch_session.title %></span>
  <% end %>

  <h1 class="fw-bold mb-4 text-white" id="chat_title"><%= @chat.title %></h1>

  <div id="messages" class="d-flex flex-column gap-3 mb-4">
    <% @messages.each do |message| %>
      <% role = message.role.to_s.strip.downcase %>
      <% is_user = (role == "user") %>

      <div class="d-flex <%= is_user ? "justify-content-end" : "justify-content-start" %>">
        <div
          class="px-3 py-2 rounded-4 shadow-sm"
          style="
            max-width: 72%;
            white-space: pre-wrap;
            word-break: break-word;
            line-height: 1.35;
            <%= is_user ?
                'background: #0d6efd; color: white; border-bottom-right-radius: 8px;' :
                'background: #f1f3f5; color: #111; border-bottom-left-radius: 8px;' %>
          "
        >
          <%= message.content %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-3">
      <%= simple_form_for [@chat, @message] do |f| %>
        <div class="d-flex gap-2 align-items-end">
          <%= f.input :content,
              label: false,
              placeholder: "I'm in the mood for...",
              required: true,
              wrapper_html: { class: "flex-grow-1 mb-0" },
              input_html: { class: "form-control bg-light rounded-3", rows: 1 } %>

          <%= f.button :submit, "Send", class: "btn btn-primary px-4 rounded-3" %>
        </div>
      <% end %>
    </div>
  </div>

</div>
