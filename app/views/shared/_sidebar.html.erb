<div class="px-3">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">Filmy</h5>

    <%= link_to "#",
          class: "nav-link text-light p-0",
          data: { action: "click->toggle#call" } do %>
      ◀
    <% end %>
  </div>

  <ul class="nav flex-column gap-2">
    <li class="nav-item">
      <%= link_to "Home", root_path, class: "nav-link text-light" %>
    </li>

    <li class="nav-item">
      <%= link_to "New Watch Session", new_watch_session_path, class: "nav-link text-light" %>
    </li>

    <li class="nav-item">
      <%= link_to "Edit account", edit_user_registration_path, class: "nav-link text-light" %>
    </li>
  </ul>

  <div class="mt-3">
    <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "btn btn-outline-light w-100" %>
  </div>
</div>
