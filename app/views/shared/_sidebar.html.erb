<div class="sidebar">
  <div class="sidebar-brand">
    <div class="d-flex align-items-center">
      <%= image_tag "https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/logo.png",
          style: "width:32px;height:32px",
          class: "me-2" %>

      <p class="brand mb-0">Filmy</p>
    </div>

    <%= link_to "#",
                class: "sidebar-link p-2",
                aria: { label: "Collapse sidebar" },
                data: { action: "click->toggle#call" } do %>
      ◀
    <% end %>
  </div>

  <div class="sidebar-section-title">Sidebar</div>
  <ul class="sidebar-nav">
    <li>
      <%= link_to "Home", root_path, class: "sidebar-link" %>
    </li>

    <li>
      <%= link_to "New Watch Session", new_watch_session_path, class: "sidebar-link" %>
    </li>

    <li>
      <%= link_to "All Watch Sessions", watch_sessions_path, class: "sidebar-link" %>
    </li>
  </ul>

  <details class="mt-2" open>
    <summary class="sidebar-link" style="cursor: pointer; list-style: none;">
      <span class="truncate">Watch Sessions</span>
    </summary>

    <ul class="sidebar-nav sidebar-sublist">
      <% if user_signed_in? %>
        <% sessions = @watch_sessions || current_user.watch_sessions.order(created_at: :desc) %>

        <% if sessions.any? %>
          <% sessions.each do |ws| %>
            <li>
              <%= link_to watch_session_path(ws), class: "sidebar-link" do %>
                <span class="truncate"><%= ws.title.presence || "Untitled session" %></span>
              <% end %>
            </li>
          <% end %>
        <% else %>
          <li>
            <span class="sidebar-link" style="opacity: 0.75;">No sessions yet</span>
          </li>
        <% end %>
      <% else %>
        <li>
          <%= link_to "Sign in", new_user_session_path, class: "sidebar-link" %>
        </li>
      <% end %>
    </ul>
  </details>

  <div class="sidebar-footer">
    <% if user_signed_in? %>
      <%= link_to edit_user_registration_path, class: "sidebar-link d-flex align-items-center" do %>

      <%= image_tag "https://kitt.lewagon.com/placeholder/users/ssaunier",
        class: "avatar me-2",
        style: "width:28px;height:28px;border-radius:50%" %>

      Edit account
    <% end %>

      <%= button_to "Log out",
                    destroy_user_session_path,
                    method: :delete,
                    class: "btn btn-outline-light mt-2" %>
    <% end %>
  </div>
</div>
