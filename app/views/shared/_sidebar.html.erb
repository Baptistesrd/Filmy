<div class="sidebar-brand">
  <span class="sidebar-brand-name">
    Filmy<span class="sidebar-brand-dot"></span>
  </span>
  <%= link_to "#",
        class: "sidebar-collapse-btn d-lg-none",
        aria: { label: "Collapse sidebar" },
        data: { action: "click->toggle#call" } do %>
    <i class="fa-solid fa-xmark"></i>
  <% end %>
</div>

<div class="sidebar-section-title">Navigation</div>
<ul class="sidebar-nav">
  <li>
    <%= link_to root_path, class: "sidebar-link #{'active' if current_page?(root_path)}" do %>
      <i class="fa-solid fa-house" style="font-size:0.8rem;width:14px"></i>
      <span>Home</span>
    <% end %>
  </li>
  <li>
    <%= link_to new_watch_session_path, class: "sidebar-link" do %>
      <i class="fa-solid fa-plus" style="font-size:0.8rem;width:14px"></i>
      <span>New session</span>
    <% end %>
  </li>
  <li>
    <%= link_to watch_sessions_path, class: "sidebar-link #{'active' if current_page?(watch_sessions_path)}" do %>
      <i class="fa-solid fa-film" style="font-size:0.8rem;width:14px"></i>
      <span>All sessions</span>
    <% end %>
  </li>
  <li>
    <%= link_to films_path, class: "sidebar-link #{'active' if current_page?(films_path)}" do %>
      <i class="fa-solid fa-bookmark" style="font-size:0.8rem;width:14px"></i>
      <span>My library</span>
    <% end %>
  </li>
  <li>
    <%= link_to discover_path, class: "sidebar-link #{'active' if current_page?(discover_path)}" do %>
      <i class="fa-solid fa-compass" style="font-size:0.8rem;width:14px"></i>
      <span>Discover</span>
    <% end %>
  </li>
</ul>

<details class="mt-3" open>
  <summary class="sidebar-link sidebar-summary">
    <i class="fa-solid fa-clapperboard" style="font-size:0.8rem;width:14px"></i>
    <span class="sidebar-truncate">Recent sessions</span>
    <span class="sidebar-chevron">▾</span>
  </summary>

  <ul class="sidebar-nav sidebar-sublist">
    <% sessions = (watch_sessions || []).first(8) %>
    <% if sessions.any? %>
      <% sessions.each do |ws| %>
        <li>
          <%= link_to watch_session_path(ws), class: "sidebar-link" do %>
            <span class="sidebar-truncate"><%= ws.title.presence || "Untitled" %></span>
          <% end %>
        </li>
      <% end %>
    <% else %>
      <li><span class="sidebar-empty">No sessions yet</span></li>
    <% end %>
  </ul>
</details>

<div class="sidebar-footer">
  <div class="sidebar-user">
    <div class="sidebar-avatar"><%= current_user.email.first.upcase %></div>
    <div class="sidebar-user-info">
      <%= link_to "Account settings", edit_user_registration_path, class: "sidebar-user-name" %>
      <span class="sidebar-user-sub"><%= current_user.email %></span>
    </div>
  </div>

  <%= button_to "Sign out",
        destroy_user_session_path,
        method: :delete,
        class: "btn sidebar-logout" %>
</div>
