<div class="d-flex justify-content-between align-items-center px-3 mb-3">
  <div class="fw-bold">Filmy</div>

  <%= link_to "#",
      class: "nav-link text-light p-0",
      data: { action: "click->toggle#call" } do %>
    <span aria-hidden="true">◀</span>
  <% end %>
</div>

<ul class="nav flex-column px-2">
  <li class="nav-item">
    <%= link_to "Home", root_path, class: "nav-link text-light" %>
  </li>

  <li class="nav-item">
    <%= link_to "New Watch Session", new_watch_session_path, class: "nav-link text-light" %>
  </li>

  <li class="nav-item">
    <%= link_to "All Watch Sessions", watch_sessions_path, class: "nav-link text-light" %>
  </li>

  <li class="nav-item my-2">
    <details class="sidebar-details">
      <summary class="nav-link text-light">
        Your watch sessions
      </summary>

      <div class="mt-2 ms-3">
        <% if watch_sessions.present? %>
          <ul class="list-unstyled mb-0">
            <% watch_sessions.each do |ws| %>
              <li class="mb-1">
                <%= link_to (ws.title.presence || "Untitled session"),
                            watch_session_path(ws),
                            class: "nav-link text-light py-1" %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="text-secondary small">No sessions yet.</div>
        <% end %>
      </div>
    </details>
  </li>

  <li class="nav-item">
    <%= link_to "Edit account", edit_user_registration_path, class: "nav-link text-light" %>
  </li>

  <li class="nav-item px-3 mt-2">
    <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "btn btn-outline-light w-100" %>
  </li>
</ul>
