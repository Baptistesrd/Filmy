<%# ─── Discover page ───────────────────────────────────────────────────────── %>

<div class="discover-wrap"
     data-controller="swipe"
     data-swipe-save-url-value="<%= swipe_preferences_path %>"
     data-swipe-more-url-value="<%= discover_path(format: :json) %>"
     data-swipe-recommend-url-value="<%= discover_recommend_path %>"
     data-swipe-csrf-value="<%= form_authenticity_token %>"
     data-swipe-category-value="<%= @category %>">

  <%# ── Top bar ──────────────────────────────────────────────────────────── %>
  <header class="discover-topbar">
    <div class="discover-brand">
      Discover<span class="discover-dot">.</span>
    </div>

    <div class="discover-stats">
      <span class="discover-stat">
        <i class="fa-solid fa-heart"></i>
        <span id="liked-count">0</span>
      </span>
      <span class="discover-stat-sep"></span>
      <span class="discover-stat">
        <i class="fa-solid fa-eye"></i>
        <span id="seen-count">0</span>
      </span>
    </div>

    <button id="rec-trigger-btn"
            class="discover-pick-btn"
            data-action="click->swipe#recommend">
      <i class="fa-solid fa-wand-magic-sparkles"></i>
      <span>My pick</span>
    </button>
  </header>

  <%# ── Category chips ──────────────────────────────────────────────────── %>
  <div class="discover-cats">
    <% [
      { key: "popular",     label: "Popular",     icon: "fa-fire" },
      { key: "trending",    label: "Trending",    icon: "fa-arrow-trend-up" },
      { key: "top_rated",   label: "Top Rated",   icon: "fa-star" },
      { key: "hidden_gems", label: "Hidden Gems", icon: "fa-gem" }
    ].each do |cat| %>
      <button class="discover-cat <%= 'discover-cat--active' if @category == cat[:key] %>"
              data-cat="<%= cat[:key] %>"
              data-action="click->swipe#switchCategory">
        <i class="fa-solid <%= cat[:icon] %>"></i>
        <%= cat[:label] %>
      </button>
    <% end %>
  </div>

  <%# ── Card stack ───────────────────────────────────────────────────────── %>
  <div class="swipe-arena" id="swipe-arena">
    <div class="swipe-stack" data-swipe-target="stack">

      <% @films.each_with_index do |film, i| %>
        <div class="swipe-card"
             data-swipe-target="card"
             data-tmdb-id="<%= film[:tmdb_id] %>"
             data-title="<%= film[:title] %>"
             data-year="<%= film[:year] %>"
             data-poster="<%= film[:poster_url] %>"
             data-synopsis="<%= film[:synopsis]&.truncate(160) %>"
             data-rating="<%= film[:tmdb_rating] %>"
             style="z-index:<%= 100 - i %>">

          <% if film[:poster_url].present? %>
            <img src="<%= film[:poster_url] %>"
                 alt="<%= film[:title] %>"
                 class="swipe-poster"
                 loading="<%= i == 0 ? 'eager' : 'lazy' %>">
          <% else %>
            <div class="swipe-poster swipe-poster--placeholder">
              <i class="fa-solid fa-film"></i>
            </div>
          <% end %>

          <div class="swipe-overlay swipe-overlay--like">
            <i class="fa-solid fa-heart"></i> LIKE
          </div>
          <div class="swipe-overlay swipe-overlay--nope">
            NOPE <i class="fa-solid fa-xmark"></i>
          </div>

          <div class="swipe-card-info">
            <h2 class="swipe-card-title"><%= film[:title] %></h2>
            <div class="swipe-card-meta">
              <% if film[:year].present? %>
                <span class="swipe-card-year"><%= film[:year] %></span>
              <% end %>
              <% if film[:tmdb_rating].present? && film[:tmdb_rating] > 0 %>
                <span class="swipe-card-rating">
                  <i class="fa-solid fa-star"></i> <%= film[:tmdb_rating] %>
                </span>
              <% end %>
            </div>
            <% if film[:synopsis].present? %>
              <p class="swipe-card-synopsis"><%= film[:synopsis].truncate(100) %></p>
            <% end %>
          </div>

        </div>
      <% end %>

      <div class="swipe-empty" data-swipe-target="empty" style="display:none">
        <div class="swipe-empty-icon"><i class="fa-solid fa-clapperboard"></i></div>
        <p>Loading…</p>
      </div>

    </div>

    <%# ── Buttons ──────────────────────────────────────────────────────────── %>
    <div class="swipe-actions">
      <button class="swipe-btn swipe-btn--skip"
              data-action="click->swipe#skipCurrent"
              aria-label="Skip">
        <i class="fa-solid fa-xmark"></i>
      </button>

      <button class="swipe-btn swipe-btn--like"
              data-action="click->swipe#likeCurrent"
              aria-label="Like">
        <i class="fa-solid fa-heart"></i>
      </button>
    </div>

    <div class="discover-keys">
      <span><kbd>←</kbd> Skip</span>
      <span>Like <kbd>→</kbd></span>
    </div>
  </div>

  <%# ── Recommendation modal ────────────────────────────────────────────── %>
  <div class="rec-overlay" id="rec-overlay">
    <div class="rec-modal">
      <button class="rec-close" data-action="click->swipe#keepSwiping" aria-label="Close">
        <i class="fa-solid fa-xmark"></i>
      </button>

      <div class="rec-poster-wrap" id="rec-poster-wrap"></div>

      <div class="rec-content">
        <div class="rec-badge">
          <i class="fa-solid fa-wand-magic-sparkles"></i> Your pick
        </div>
        <p class="rec-message" id="rec-message"></p>
        <div class="rec-film-info">
          <h2 class="rec-title" id="rec-title"></h2>
          <div class="rec-meta" id="rec-meta"></div>
        </div>
        <div class="rec-actions">
          <button class="rec-btn rec-btn--ghost" data-action="click->swipe#keepSwiping">
            <span class="bi-default">
              <span class="bi-dot"></span>
              <span>Keep swiping</span>
            </span>
            <span class="bi-hover">
              <i class="fa-solid fa-rotate-left"></i>
              <span>Keep swiping</span>
            </span>
          </button>
          <a class="rec-btn rec-btn--amber"
             id="rec-trailer"
             href="#"
             target="_blank"
             rel="noopener"
             style="display:none">
            <span class="bi-default">
              <span class="bi-dot"></span>
              <span>Trailer</span>
            </span>
            <span class="bi-hover">
              <i class="fa-brands fa-youtube"></i>
              <span>Trailer</span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>

</div>
