<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Filmy" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Filmy">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= link_to "Skip to main content", "#main-content", class: "visually-hidden-focusable" %>

    <header>
      <%= render "shared/navbar" %>
    </header>

    <div class="container-fluid">
      <div class="row" data-controller="toggle">
        <!-- Sidebar -->
        <nav class="col-md-2 sidebar pt-3" data-toggle-target="hideable">
          <%= render "shared/sidebar" %>
        </nav>

        <!-- Main content -->
        <main id="main-content" class="col-md-10 my-4">
          <!-- Re-open sidebar button (only shows when sidebar is hidden) -->
          <%= link_to "#",
                class: "d-none nav-link text-light mb-3",
                data: { action: "click->toggle#call", toggle_target: "show" } do %>
            ▶ Open menu
          <% end %>

          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
