<div class="film-panel">
  <div class="film-panel-header">
    <h2><i class="fa-solid fa-film" style="color:var(--accent);font-size:0.9rem;margin-right:6px"></i>Picks for you</h2>
    <span class="film-panel-count"><%= recommended_films.size %></span>
  </div>

  <div class="film-panel-body">
    <% if recommended_films.any? %>
      <% recommended_films.each do |film| %>
        <%= render "recommended_films/card", film: film %>
      <% end %>
    <% else %>
      <div class="film-panel-empty">
        <i class="fa-regular fa-compass"></i>
        Ask me what you're in the mood for and your picks will appear here.
      </div>
    <% end %>
  </div>
</div>
