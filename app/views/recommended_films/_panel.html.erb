<div class="card border-0 shadow-sm rounded-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <h2 class="h6 mb-0 text-dark">Recommended</h2>
      <span class="badge bg-light text-dark"><%= recommended_films.size %></span>
    </div>

    <% if recommended_films.any? %>
      <div class="d-flex flex-column gap-3">
        <% recommended_films.each do |film| %>
          <%= render "recommended_films/card", film: film %>
        <% end %>
      </div>
    <% else %>
      <p class="text-white-50 mb-0">Ask for recommendations and they'll appear here.</p>
    <% end %>
  </div>
</div>
