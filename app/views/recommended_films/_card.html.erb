<div id="<%= dom_id(film) %>" class="rec-film-card" data-controller="film-card">

  <% if film.poster_url.present? %>
    <%= image_tag film.poster_url, alt: film.title, class: "rec-film-poster" %>
  <% else %>
    <div class="rec-film-poster-placeholder">
      <i class="fa-solid fa-clapperboard" style="font-size:1rem;opacity:0.4"></i>
    </div>
  <% end %>

  <div class="rec-film-info">
    <div class="rec-film-title"><%= film.title %></div>
    <div class="rec-film-meta">
      <%= film.year %>
      <% if film.runtime.present? %> · <%= film.runtime %> min<% end %>
    </div>

    <% if film.blurb.present? %>
      <div class="rec-film-blurb"><%= film.blurb %></div>
    <% end %>

    <div class="rec-film-actions">
      <% if film.added? %>
        <span class="rec-film-saved">
          <i class="fa-solid fa-check"></i> Saved
        </span>
      <% else %>
        <%= button_to save_recommended_film_path(film),
              method: :post,
              class: "btn-accent-ghost",
              form: { data: { turbo_stream: true } } do %>
          <i class="fa-solid fa-plus" style="font-size:0.75rem"></i> Save
        <% end %>
      <% end %>
    </div>
  </div>

</div>
