<div class="film-card" id="<%= dom_id(film) %>">
  <div class="d-flex justify-content-between align-items-start">
    <div class="me-2">
      <div class="film-title"><%= film.title %> <span class="film-meta">(<%= film.year %>)</span></div>
      <div class="film-meta"><%= film.runtime.present? ? "#{film.runtime} min" : "" %></div>
    </div>

    <% if film.added? %>
      <span class="badge bg-success">Added</span>
    <% else %>
      <%= button_to "＋",
          watchlist_items_path(recommended_film_id: film.id),
          method: :post,
          form: { data: { turbo: true } },
          class: "btn btn-sm btn-primary film-add" %>
    <% end %>
  </div>

  <% if film.blurb.present? %>
    <div class="film-blurb mt-2"><%= film.blurb %></div>
  <% end %>
</div>
