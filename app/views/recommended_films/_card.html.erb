<div id="<%= dom_id(film) %>"
     class="card border-0 shadow-sm rounded-4 mb-2"
     data-controller="film-card">

  <div class="card-body py-2">
    <div class="d-flex justify-content-between align-items-center">

      <div>
        <div class="fw-semibold text-dark">
          <%= film.title %><% if film.year.present? %> (<%= film.year %>)<% end %>
        </div>

        <% if film.runtime.present? %>
          <div class="small text-muted"><%= film.runtime %> min</div>
        <% end %>
      </div>

      <% unless film.added? %>
        <%= button_to add_recommended_film_path(film),
              method: :post,
              class: "btn btn-primary btn-sm",
              form: { data: { turbo_stream: true } } do %>
          +
        <% end %>
      <% else %>
        <span class="text-success fw-bold">✓</span>
      <% end %>

    </div>
  </div>
</div>
