<div class="hero">
  <div class="hero-content">
    <h1 class="logo"%>Filmy</h1>
    <p class="tagline">Forget Netflix. Forget Letterboxd.</p>

    <% if user_signed_in? %>
      <div class="cta-group">
        <%= link_to new_watch_session_path, class: "cta-btn cta-btn--primary" do %>
          <span class="cta-btn__icon">▶</span>
          <span class="cta-btn__text">Start the session</span>
        <% end %>

        <%= link_to watch_sessions_path, class: "cta-btn cta-btn--primary" do %>
          <span class="cta-btn__icon">◈</span>
          <span class="cta-btn__text">See all my sessions</span>
        <% end %>
      </div>
    <% else %>
      <%= link_to new_user_session_path, class: "cta-btn cta-btn--primary" do %>
        <span class="cta-btn__text">Start now</span>
        <span class="cta-btn__arrow">→</span>
      <% end %>
    <% end %>
  </div>
</div>
