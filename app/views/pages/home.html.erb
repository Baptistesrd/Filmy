<div class="hero">
  <div class="hero-content">
    <p class="hero-eyebrow">Your cinematic companion</p>

    <h1 class="hero-title">Filmy</h1>

    <p class="hero-tagline">
      Tell us how you feel.<br>
      We'll find the perfect film.
    </p>

    <div class="hero-cta">
      <% if user_signed_in? %>
        <%= link_to new_watch_session_path, class: "hero-btn-primary" do %>
          <i class="fa-solid fa-play" style="font-size:0.8rem"></i>
          Start a session
        <% end %>

        <%= link_to watch_sessions_path, class: "hero-btn-ghost" do %>
          My sessions
        <% end %>
      <% else %>
        <%= link_to new_user_registration_path, class: "hero-btn-primary" do %>
          Get started — it's free
          <i class="fa-solid fa-arrow-right" style="font-size:0.8rem"></i>
        <% end %>

        <%= link_to new_user_session_path, class: "hero-btn-ghost" do %>
          Sign in
        <% end %>
      <% end %>
    </div>
  </div>
</div>
